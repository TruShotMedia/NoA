{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "same-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/grocery-list",
      "destination": "/index.html"
    },
    {
      "source": "/grocery-list/:path*",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/budget/tenant-email-schedule",
      "schedule": "0 22 * * *"
    }
  ]
}
